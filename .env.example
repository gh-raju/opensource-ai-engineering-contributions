# Covenant — example environment file.
#
# Copy this to `.env` and fill in real values:  cp .env.example .env
# `.env` is gitignored and must NEVER be committed. Prefer your OS keychain or a
# secret manager for real secrets wherever possible.

# --- GitHub (for pushing this repo) ---
# NOTE: For `git push`, the MOST secure option is NOT this file — it is the macOS Keychain
# credential helper, which is already configured for this repo. Just run `git push` and paste
# your fine-grained PAT once when prompted; the OS then stores it encrypted.
# Only set GITHUB_TOKEN below if a script/tool of yours reads the token from the environment.
GITHUB_TOKEN=

# --- LLM providers (only needed later, for optional LLM-as-judge policies) ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
